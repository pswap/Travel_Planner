# Example environment variables (safe to commit)
# 1) Copy this file to `.env`:  cp .env.example .env
# 2) Replace the placeholder values with your real API keys

# Required: OpenAI (LLM + embeddings)
OPENAI_API_KEY=your_openai_key_here

# Required: Pinecone (RAG vector store for itinerary agent)
PINECONE_API_KEY=your_pinecone_key_here

# Required: Tavily (web search for itinerary agent)
TAVILY_API_KEY=your_tavily_key_here

# Optional: SerpAPI (flight + hotel search; omit to disable those tools)
SERPAPI_API_KEY=your_serpapi_key_here

# Optional: LangSmith / LangChain tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langchain_key_here
LANGCHAIN_PROJECT=travel-planner
